# CoreGist News Backend Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================
# Database Configuration
# ============================================
# Local MongoDB connection string
MONGODB_URI=mongodb://127.0.0.1:27017/coregistnews

# Database name
MONGODB_DB_NAME=coregistnews

# Docker MongoDB connection (for docker-compose)
DOCKER_MONGODB_URI=mongodb://root:example@mongodb:27017/coregistnews?authSource=admin

# MongoDB Object ID (if needed)
MOGGODB_ID=

# ============================================
# Service Ports
# ============================================
# Legacy port (deprecated, use GATEWAY_PORT)
PORT=8000

# API Gateway port (main entry point)
GATEWAY_PORT=3000

# User service port
USER_SERVICE_PORT=3001

# News service port
NEWS_SERVICE_PORT=3002

# Agent config service port
AGENT_CONFIG_PORT=3003

# Skill config service port
SKILL_CONFIG_PORT=3004

# ============================================
# AI Service API Keys
# ============================================
# Google Gemini API key
GEMINI_API_KEY=your-gemini-api-key-here

# Backup Gemini API key
GEMINI_API_KEY1=your-backup-gemini-key-here

# Gemini model to use
GEMINI_MODEL=gemini-2.0-flash

# OpenAI API key
OPENAI_API_KEY=your-openai-api-key-here

# OpenAI POE key (if using POE)
OPENAI_POE_KEY=your-poe-key-here

# Claude API key (if using Claude)
OPEN_CLAUDE_KEY=your-claude-key-here

# DMAX API key
DMAX_API=your-dmax-api-key-here

# ============================================
# AI Model Configuration
# ============================================
# Content generation model (dmax, openai, gemini)
AI_CONTENT_MODEL=dmax

# Review model (dmax, openai, gemini)
AI_REVIEW_MODEL=dmax

# Remote model name for review
AI_REVIEW_REMOTE_MODEL=Qwen3.5-2B-free

# Review API base URL
AI_REVIEW_BASE_URL=https://www.dmxapi.cn/v1

# Review API key
AI_REVIEW_API_KEY=

# OpenRouter model
OPENROUTER_MODEL=z-ai/glm-4.5-air:free

# OpenRouter HTTP referer
OPENROUTER_HTTP_REFERER=http://localhost:5173

# OpenRouter app title
OPENROUTER_TITLE=CoreGist News

# LLM request timeout in milliseconds
LLM_REQUEST_TIMEOUT_MS=60000

# Content generation API base URL
AI_CONTENT_BASE_URL=https://www.dmxapi.cn/v1

# Content generation remote model
AI_CONTENT_REMOTE_MODEL=Qwen3.5-2B-free

# Content generation API key
AI_CONTENT_API_KEY=

# DMAX base URL
DMAX_BASE_URL=https://www.dmxapi.cn/v1

# DMAX remote model
DMAX_REMOTE_MODEL=Qwen3.5-2B-free

# ============================================
# VPN/Proxy Configuration (Optional)
# ============================================
# VPN host
VPN_HOST=127.0.0.1

# VPN port
VPN_PORT=9981

# ============================================
# JWT Authentication
# ============================================
# JWT secret for access tokens (REQUIRED - generate a strong random string)
JWT_SECRET=your-jwt-secret-here

# JWT secret for refresh tokens (REQUIRED - generate a strong random string)
JWT_REFRESH_SECRET=your-jwt-refresh-secret-here

# Access token expiration in seconds (default: 7 days)
ACCESS_TOKEN_EXPIRES_SECONDS=604800

# Refresh token expiration in seconds (default: 30 days)
REFRESH_TOKEN_EXPIRES_SECONDS=2592000

# Password reset code expiration in minutes (default: 10 minutes)
RESET_CODE_EXPIRES_MINUTES=10

# ============================================
# Google OAuth (Optional)
# ============================================
# Google OAuth client ID
GOOGLE_CLIENT_ID=your-google-client-id-here

# ============================================
# Firebase (Optional)
# ============================================
# Firebase project ID
FIREBASE_PROJECT_ID=coregistnews-news

# ============================================
# Message Queue (Optional)
# ============================================
# RabbitMQ connection URL
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# ============================================
# Cache (Optional)
# ============================================
# Redis connection URL
REDIS_URL=redis://localhost:6379

# ============================================
# Scraping Configuration
# ============================================
# Default search query for news scraping
SEARCH_DEFAULT_QUERY=AI Agent 最新进展

# Maximum items per RSS feed
RSS_MAX_ITEMS_PER_FEED=20

# Hard limit for RSS items per feed
RSS_MAX_ITEMS_PER_FEED_HARD_LIMIT=50

# Scheduler interval in minutes
SCHEDULER_INTERVAL_MINUTES=30

# ============================================
# Notes
# ============================================
# 1. Generate strong random strings for JWT secrets:
#    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# 2. Never commit the actual .env file to version control
#
# 3. For production, use environment-specific values and rotate secrets regularly
#
# 4. Minimum required variables for basic operation:
#    - MONGODB_URI
#    - JWT_SECRET
#    - JWT_REFRESH_SECRET
#    - At least one AI API key (GEMINI_API_KEY or OPENAI_API_KEY)
