# CoreGist News backend environment template
# Copy this file to backend/.env and replace placeholder values.
# Do not commit backend/.env or any real secrets.

# ============================================
# Runtime
# ============================================
NODE_ENV=development

# Legacy fallback port. Gateway normally uses GATEWAY_PORT.
PORT=8000

GATEWAY_PORT=3000
USER_SERVICE_PORT=3001
NEWS_SERVICE_PORT=3002
SEARCH_SERVICE_PORT=3005

USER_SERVICE_URL=http://127.0.0.1:3001
NEWS_SERVICE_URL=http://127.0.0.1:3002
SEARCH_SERVICE_URL=http://127.0.0.1:3005

# ============================================
# MongoDB
# ============================================
# Local development without auth.
MONGODB_URI=mongodb://127.0.0.1:27017/coregistnews
MONGODB_DB_NAME=coregistnews

# Docker Compose MongoDB URI.
DOCKER_MONGODB_URI=mongodb://root:example@mongodb:27017/coregistnews?authSource=admin
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=example

# Production example:
# MONGODB_URI=mongodb://username:password@127.0.0.1:27017/coregistnews?authSource=coregistnews

# ============================================
# RabbitMQ / Redis
# ============================================
RABBITMQ_URL=amqp://guest:guest@127.0.0.1:5672/
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
RABBITMQ_HEARTBEAT_SECONDS=300
RABBITMQ_BLOCKED_CONNECTION_TIMEOUT_SECONDS=360

REDIS_URL=redis://127.0.0.1:6379

# Queue pressure guards. Scraper skips new crawl work when queues are heavily backlogged.
NEWS_RAW_QUEUE_MAX_MESSAGES=5000
AI_TASKS_QUEUE_MAX_MESSAGES=1000
RSS_SKIP_WHEN_BACKLOGGED=true

# ============================================
# Authentication
# ============================================
# Generate strong random values:
#   openssl rand -base64 32
JWT_SECRET=change-me-generate-a-strong-random-string
JWT_REFRESH_SECRET=change-me-generate-a-different-strong-random-string

ACCESS_TOKEN_EXPIRES_SECONDS=604800
REFRESH_TOKEN_EXPIRES_SECONDS=2592000
RESET_CODE_EXPIRES_MINUTES=10

# Google OAuth client ID, optional.
GOOGLE_CLIENT_ID=

# Firebase project ID for verifying frontend Firebase login tokens.
FIREBASE_PROJECT_ID=coregistnews-news
# Local development may set true if Firebase public certs are unreachable.
# Production must keep false.
ALLOW_UNVERIFIED_FIREBASE_TOKENS=false

# ============================================
# LLM provider
# ============================================
# Supported providers: openai-compatible, anthropic, mock.
LLM_PROVIDER=openai-compatible
LLM_BASE_URL=https://your-provider.example/v1
LLM_API_KEY=your-api-key
LLM_MODEL=your-model
LLM_JSON_MODE=false
LLM_TOKEN_FIELD=max_tokens
LLM_TOP_P=
LLM_FREQUENCY_PENALTY=
LLM_PRESENCE_PENALTY=
LLM_SYSTEM_PROMPT=
LLM_EXTRA_BODY_JSON=
LLM_HTTP_REFERER=http://localhost:5173
LLM_TITLE=CoreGist News
LLM_TIMEOUT_SECONDS=45

# MiMo OpenAI-compatible example:
# LLM_PROVIDER=openai-compatible
# LLM_BASE_URL=https://api.xiaomimimo.com/v1
# LLM_API_KEY=your-mimo-api-key
# LLM_MODEL=mimo-v2.5
# LLM_JSON_MODE=false
# LLM_TOKEN_FIELD=max_completion_tokens
# LLM_TOP_P=0.95
# LLM_EXTRA_BODY_JSON={"thinking":{"type":"disabled"}}

# Anthropic native example:
# LLM_PROVIDER=anthropic
# LLM_BASE_URL=https://api.anthropic.com
# LLM_API_KEY=your-anthropic-api-key
# LLM_MODEL=claude-3-5-haiku-latest
# ANTHROPIC_VERSION=2023-06-01

# Ollama OpenAI-compatible example:
# LLM_PROVIDER=openai-compatible
# LLM_BASE_URL=http://127.0.0.1:11434/v1
# LLM_API_KEY=
# LLM_MODEL=llama3.1

# ============================================
# AI pipeline
# ============================================
# Content model defaults to LLM_PROVIDER / LLM_BASE_URL / LLM_API_KEY / LLM_MODEL.
AI_CONTENT_MODEL=openai-compatible
AI_CONTENT_LLM_MODEL=
AI_CONTENT_BASE_URL=
AI_CONTENT_API_KEY=
AI_CONTENT_MAX_TOKENS=900
AI_CONTENT_CHAR_LIMIT=4500
AI_CONTENT_TEMPERATURE=0
AI_CONTENT_JSON_MODE=false

# Keep classification rule-first by default to reduce model pressure and 429 risk.
CONTENT_CLASSIFICATION_LLM_ENABLED=false

# Review model defaults to LLM_PROVIDER / LLM_BASE_URL / LLM_API_KEY / LLM_MODEL.
AI_REVIEW_MODEL=openai-compatible
AI_REVIEW_LLM_MODEL=
AI_REVIEW_BASE_URL=
AI_REVIEW_API_KEY=
AI_REVIEW_MAX_TOKENS=1200
AI_REVIEW_CHAR_LIMIT=3500
AI_REVIEW_TEMPERATURE=0.1
AI_REVIEW_JSON_MODE=false

AI_WORKER_CONCURRENCY=5
RETRY_MAX_RETRIES=3
RETRY_BASE_DELAY_MS=60000
RETRY_MAX_DELAY_MS=1800000
RETRY_EXPONENTIAL_BASE=3

# Prevent duplicate ingestion while a source item is still being processed.
NEWS_INGESTION_LOCK_HOURS=24

# ============================================
# Scheduler / RSS crawler
# ============================================
SEARCH_DEFAULT_QUERY=AI Agent 最新进展
SCHEDULER_DEFAULT_QUERY=
SCHEDULER_INTERVAL_MINUTES=30

RSS_MAX_ITEMS_PER_FEED=20
RSS_MAX_ITEMS_PER_FEED_HARD_LIMIT=50
RSS_SOURCE_BATCH_SIZE=8
RSS_SOURCE_MIN_INTERVAL_SECONDS=900
RSS_DOMAIN_MIN_INTERVAL_SECONDS=300
RSS_SOURCE_ERROR_BACKOFF_SECONDS=1800
RSS_ROTATION_STATE_COLLECTION=rss_crawl_state

RSS_VERIFY_SSL=true
RSS_ALLOW_INSECURE_HOSTS=
RSS_REQUEST_TIMEOUT_SECONDS=10
RSS_FEED_TIMEOUT_MS=8000
RSS_BROWSER_TIMEOUT_MS=12000

RSS_TIMEOUT_BACKOFF_SECONDS=1800
RSS_BROWSER_TIMEOUT_BACKOFF_SECONDS=3600
RSS_HTTP_LIMITED_BACKOFF_SECONDS=21600
RSS_TIMEOUT_QUARANTINE_THRESHOLD=5
RSS_HTTP_LIMITED_QUARANTINE_THRESHOLD=3
RSS_TIMEOUT_QUARANTINE_SECONDS=21600
RSS_HTTP_LIMITED_QUARANTINE_SECONDS=86400
RSS_QUARANTINE_REPEATS_TO_DISABLE=3
RSS_DISABLE_AFTER_FAILURES=12

# Optional worker split. Valid values: combined, rss, keyword.
NEWS_SCRAPER_WORKER_MODE=combined

# ============================================
# Push / tracking / notification
# ============================================
NOTIFICATION_EMAIL=user@example.com
PUSH_TIMEZONE=Asia/Shanghai
PUSH_DUE_WINDOW_MINUTES=5
PUSH_EXISTING_NEWS_LOOKBACK_HOURS=72
PUSH_BATCH_COMPLETION_TIMEOUT_MINUTES=30
PUSH_MAX_ENRICHMENT_PER_BATCH=20

TRACKING_DEFAULT_FREQUENCY_MINUTES=30
TRACKING_MIN_FREQUENCY_MINUTES=15
TRACKING_DEFAULT_REMAINING_COUNT=5
TRACKING_MAX_REMAINING_COUNT=10

# Firebase Cloud Messaging legacy server key, optional.
FCM_SERVER_KEY=

# ============================================
# Local proxy, optional
# ============================================
VPN_HOST=127.0.0.1
VPN_PORT=9981

# ============================================
# Notes
# ============================================
# Minimum required for local API services:
#   MONGODB_URI
#   JWT_SECRET
#   JWT_REFRESH_SECRET
#
# Minimum required for the full news AI pipeline:
#   MONGODB_URI
#   RABBITMQ_URL
#   LLM_PROVIDER
#   LLM_BASE_URL
#   LLM_API_KEY
#   LLM_MODEL
#
# Production reminders:
#   - Replace all placeholder secrets.
#   - Keep ALLOW_UNVERIFIED_FIREBASE_TOKENS=false.
#   - Prefer private 127.0.0.1 service URLs behind the Gateway.
#   - Rotate secrets if they ever appear in chat logs, shell history, or git history.
