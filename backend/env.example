# MongoDB 连接字符串
# 本地 MongoDB（无认证）
MONGODB_URI=mongodb://127.0.0.1:27017/coregistnews
MONGODB_DB_NAME=coregistnews
# DOCKER_MONGODB_URI=mongodb://root:example@mongodb:27017/coregistnews?authSource=admin

# 本地 MongoDB（有认证）
# MONGODB_URI=mongodb://username:password@127.0.0.1:27017/coregistnews?authSource=admin

# 远程 MongoDB
# MONGODB_URI=mongodb://username:password@your-mongodb-host:27017/coregistnews?authSource=admin

# JWT 密钥（必须修改为强随机字符串）
# 生成方法: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-to-random-string
# 刷新 token 密钥（不填则默认使用 JWT_SECRET）
# JWT_REFRESH_SECRET=your-refresh-token-secret
# Access token 有效期（秒），默认 604800（7 天）
# ACCESS_TOKEN_EXPIRES_SECONDS=604800
# Refresh token 有效期（秒），默认 2592000（30 天）
# REFRESH_TOKEN_EXPIRES_SECONDS=2592000
# 重置密码验证码有效期（分钟），默认 10
# RESET_CODE_EXPIRES_MINUTES=10

# 后端服务端口
PORT=8000

# 网关与微服务端口
# GATEWAY_PORT=3000
# USER_SERVICE_PORT=3001
# NEWS_SERVICE_PORT=3002
# AGENT_CONFIG_PORT=3003
# SKILL_CONFIG_PORT=3004

# Docker/RabbitMQ
# RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
# RABBITMQ_DEFAULT_USER=guest
# RABBITMQ_DEFAULT_PASS=guest
# MONGO_INITDB_ROOT_USERNAME=root
# MONGO_INITDB_ROOT_PASSWORD=example

# 通用大模型接口配置
# LLM_PROVIDER=openai-compatible
# LLM_BASE_URL=https://www.dmxapi.cn/v1
# LLM_API_KEY=your-api-key
# LLM_MODEL=MiniMax-M2.7-free
# LLM_JSON_MODE=false
# LLM_HTTP_REFERER=http://localhost:5173
# LLM_TITLE=CoreGist News
#
# Anthropic 原生接口示例
# LLM_PROVIDER=anthropic
# LLM_BASE_URL=https://api.anthropic.com
# LLM_API_KEY=your-anthropic-api-key
# LLM_MODEL=claude-3-5-haiku-latest
# ANTHROPIC_VERSION=2023-06-01
#
# Ollama OpenAI-compatible 示例
# LLM_PROVIDER=openai-compatible
# LLM_BASE_URL=http://127.0.0.1:11434/v1
# LLM_API_KEY=
# LLM_MODEL=llama3.1
#
# 兼容旧 DMAX/OpenRouter 变量；新部署优先使用上面的 LLM_*。
# DMAX_API=your-dmax-api-key-here
# DMAX_BASE_URL=https://www.dmxapi.cn/v1
# DMAX_MODEL=MiniMax-M2.7-free
# OPENROUTER_API_KEY=your-openrouter-api-key
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=google/gemma-3-4b-it:free

# AI 分析模型配置
# 主内容模型：默认跟随 LLM_PROVIDER；可单独覆盖。
# AI_CONTENT_MODEL=openai-compatible
# AI_CONTENT_LLM_MODEL=
# AI_CONTENT_MAX_TOKENS=900
# AI_CONTENT_CHAR_LIMIT=4500
# AI_CONTENT_TEMPERATURE=0
# AI_CONTENT_JSON_MODE=false
#
# 高质量复核模型：默认跟随 LLM_PROVIDER；可单独覆盖。
# AI_REVIEW_MODEL=openai-compatible
# AI_REVIEW_LLM_MODEL=
# AI_REVIEW_MAX_TOKENS=1200
# AI_REVIEW_CHAR_LIMIT=3500
# AI_REVIEW_TEMPERATURE=0.1
# AI_REVIEW_JSON_MODE=false
# LLM_REQUEST_TIMEOUT_MS=60000

# Google OAuth 配置（用于Google登录功能）
# 获取方法：https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Firebase 项目 ID（用于兼容前端 Firebase 登录 token）
# 默认值为 coregistnews-news，如项目不同请修改
# FIREBASE_PROJECT_ID=coregistnews-news
# 本地开发网络无法访问 Firebase 公钥时允许降级解码 Firebase ID Token。
# start-local-backend.sh 会为本地服务默认设为 true；生产环境必须保持 false 或不设置。
# ALLOW_UNVERIFIED_FIREBASE_TOKENS=false

# 调度
# SEARCH_DEFAULT_QUERY=AI Agent 最新进展
# SCHEDULER_INTERVAL_MINUTES=30
# RSS_MAX_ITEMS_PER_FEED=20
# RSS_MAX_ITEMS_PER_FEED_HARD_LIMIT=50
# NOTIFICATION_EMAIL=user@example.com
